# Relayium server configuration (copy to .env and edit).
#
# Every CLI flag has a RELAYIUM_* fallback. Precedence, highest first:
#   1. explicit CLI flag (e.g. -admin-pass ...)
#   2. a real environment variable
#   3. this .env file
#   4. the built-in default
#
# .env is git-ignored; never commit real secrets. Point at a different file
# with RELAYIUM_ENV_FILE=/path/to/file (a real env var, not set here).

# --- Admin dashboard ---
# Credentials for the read-only /admin user list.
# Username defaults to "admin" if unset. Password empty disables /admin entirely.
RELAYIUM_ADMIN_USER=admin
RELAYIUM_ADMIN_PASS=

# --- Core ---
# RELAYIUM_ADDR=:8080
# RELAYIUM_BASE_URL=http://localhost:8080
# RELAYIUM_DB=relayium.db
# RELAYIUM_STATIC=../web/dist

# --- Login methods (off by default; the code is preserved) ---
# RELAYIUM_ENABLE_GOOGLE=false
# RELAYIUM_ENABLE_MAGIC=false
# RELAYIUM_GOOGLE_ID=
# RELAYIUM_GOOGLE_SECRET=

# --- SMTP (only used when magic-link is enabled) ---
# RELAYIUM_SMTP_ADDR=
# RELAYIUM_SMTP_FROM=no-reply@relayium.com
# RELAYIUM_SMTP_USER=
# RELAYIUM_SMTP_PASS=

# --- TURN / STUN / metering ---
# RELAYIUM_TURN_SECRET=
# RELAYIUM_TURN_URLS=
# RELAYIUM_STUN_URLS=stun:stun.l.google.com:19302
# RELAYIUM_REDIS_ADDR=
